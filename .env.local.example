# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real keys.

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here

# Pinecone index — must be created with dimension=3072 (gemini-embedding-2)
# Run:  npm run create-index
PINECONE_INDEX_NAME=budget-proposals-hybrid

# Google Gemini (metadata extraction, translation, reranking, embeddings)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# LlamaParse — PDF parsing via cloud (https://cloud.llamaindex.ai)
LLAMA_CLOUD_API_KEY=your_llamaparse_api_key_here

# Vercel Blob — persistent storage for data/*.json stores and uploaded PDFs
# Create a Blob store in the Vercel project dashboard to get this token
BLOB_READ_WRITE_TOKEN=your_vercel_blob_rw_token_here

# Trigger.dev — background tasks for PDF ingestion/vectorization
# Get this from the Trigger.dev project dashboard
TRIGGER_SECRET_KEY=your_trigger_secret_key_here
TRIGGER_PROJECT_REF=your_trigger_project_ref_here

# Public site URL — used by Trigger.dev tasks to fetch PDFs shipped in
# public/assets/pdfs (no trailing slash)
SITE_URL=https://your-deployment.vercel.app
